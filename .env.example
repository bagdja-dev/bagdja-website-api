## ─── Server ─────────────────────────────────────────────
PORT=5003
NODE_ENV=development

## ─── Database (Supabase Postgres) ───────────────────────
# Local Supabase (default): postgresql://postgres:postgres@localhost:54342/postgres
# Production: gunakan connection string dari Supabase project.
DATABASE_URL=postgresql://postgres:postgres@localhost:54342/postgres

## ─── Supabase (untuk migrations & storage) ──────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=website-assets

## ─── Bagdja Platform Integration ────────────────────────
# Auth service (JWT validation via JWKS)
BAGDJA_AUTH_API=http://localhost:4001
JWKS_URL=http://localhost:4001/.well-known/jwks.json

# Log service (opsional, non-blocking)
BAGDJA_LOG_URL=http://localhost:4087
BAGDJA_SERVICE_NAME=bagdja-website-api

# Client credentials untuk service-to-service (di-issue oleh bagdja-auth)
CLIENT_APP_ID=website-builder
CLIENT_APP_SECRET=change-me

# Messaging service (staff invitation email)
BAGDJA_MESSAGE_API=https://messaging.bagdja.com
ADMIN_APP_URL=http://localhost:5004
STAFF_INVITATION_TEMPLATE=StaffInvitation

## ─── JWT ─────────────────────────────────────────────────
# Secret untuk verifikasi JWT token (sama dengan yang digunakan di bagdja-auth)
JWT_SECRET=your-jwt-secret

## ─── Swagger (Basic Auth) ───────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me
